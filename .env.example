# ============================================================
# App A — oauth2-proxy for app-a
# ============================================================
APP_A_DOMAIN=app-a.example.com
APP_A_UPSTREAM=http://app-a:5678
APP_A_CLIENT_ID=app-a
APP_A_CLIENT_SECRET=change-me
# Generate with: openssl rand -hex 16
APP_A_COOKIE_SECRET=<run: openssl rand -hex 16>

# ============================================================
# App B — oauth2-proxy for app-b
# ============================================================
APP_B_DOMAIN=app-b.example.com
APP_B_UPSTREAM=http://app-b:3000
APP_B_CLIENT_ID=app-b
APP_B_CLIENT_SECRET=change-me
# Generate with: openssl rand -hex 16
APP_B_COOKIE_SECRET=<run: openssl rand -hex 16>

# ============================================================
# Google OAuth2 credentials
# Create at: https://console.cloud.google.com/apis/credentials
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# Microsoft OAuth2 credentials
# Create at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# ============================================================
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
